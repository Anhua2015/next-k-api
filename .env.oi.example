# Next K API — King Keltner 实盘（推荐配置）
# 复制为 next-k-api/.env.oi

NEXT_K_EMBED_SCHEDULER=1

# DATA_DIR=/data

# ═══════════════════════════════════════════════════════════════
# King Keltner — 唯一交易策略
# ═══════════════════════════════════════════════════════════════
# 引擎：vnpy = CTA 本地 Stop + Protocol 跳板 | paper = 仅纸面回测/影子
KK_ENGINE=vnpy
KK_ENABLED=1
KK_LIVE_ENABLED=1

# 固定 IP 机上的 protocol（同机部署用 127.0.0.1）
PROTOCOL_API_URL=http://127.0.0.1:8001

# 标的池：7 标 × 1 机器人（config/kk/symbols.txt）
# KK_SYMBOLS_FILE=
# KK_SYMBOLS=INTC,SOXL,HOOD

# 每机器人初始权益（14U × 7 ≈ 98U 总名义池）
KK_EQUITY_USDT=14
KK_RISK_PCT=0.01
# KK_COMPOUND=1
# KK_MAX_NOTIONAL_USDT=0
KK_MAX_OPEN_POSITIONS=7
KK_LIVE_LEVERAGE=5

# 会话（美股 RTH + EOD 强平，读 ORB_SESSION_* 时区配置）
KK_RTH_ONLY=1
KK_EOD_FLAT=1
KK_EXIT_HOUR=15
KK_EXIT_MINUTE=55
KK_MACRO_FILTER=1

# vnpy 常驻（API lifespan 内 supervisor 自动拉起；独立进程设 KK_VNPY_STANDALONE=1）
KK_VNPY_AUTO_START=1
# KK_VNPY_IDLE_OUTSIDE_RTH=1
# KK_VNPY_POLL_SEC=1
# KK_VNPY_TICK_SEC=1
# KK_PROTOCOL_WAIT_SEC=90

# 纸面引擎专用（KK_ENGINE=paper 时）
# KK_SCHEDULER_ENABLED=1
# KK_SCAN_INTERVAL_MINUTES=1
# KK_SHADOW=1
# KK_LIVE_ENABLED=0

# 币安 K 线（vnpy 拉历史/行情用）
# BINANCE_FAPI_BASE=https://fapi.binance.com
# HTTPS_PROXY=http://127.0.0.1:7890

# ═══════════════════════════════════════════════════════════════
# Railway：在 Dashboard 设环境变量即可，无需 start.sh
# Deploy → uvicorn main:app → lifespan 自动拉起 kk_vnpy
# ═══════════════════════════════════════════════════════════════
