# 复制为 next-k-api/.env.oi（本地）或写入 Railway 环境变量
# 单服务：API 进程内嵌定时任务，无需再跑 scheduler_main.py

NEXT_K_EMBED_SCHEDULER=1
ZCT_VWAP_SIGNAL_SCHEDULER_ENABLED=1

# 数据目录（Railway 挂载 Volume 时通常为 /data）
# DATA_DIR=/data

# 维护：清库 / 手动 Cron（生产建议设置）
# NEXT_K_MAINTENANCE_TOKEN=your-secret

# 可选
# S6_FUTURES_ALPHA_SCHEDULER_ENABLED=1
# OI_RADAR_REFRESH_COOLDOWN_SEC=120
# ZCT_VWAP_SCAN_INTERVAL_MINUTES=12
# ZCT_VWAP_RESOLVE_INTERVAL_MINUTES=5

# ── 币安实盘桥（可选，不设则模块不加载）─────────────────────────────────────
# BINANCE_ENABLED=1                       # 启用实盘桥；关闭则不加载任何 binance 代码
# BINANCE_API_KEY=your-api-key            # 币安 API Key（或启动后通过 /api/binance/config 写入 DB）
# BINANCE_API_SECRET=your-api-secret      # 币安 API Secret
# BINANCE_TESTNET=false                   # true = 使用 testnet.binancefuture.com
# BINANCE_MARGIN_USDT=100                # 单笔保证金（USDT），实际名义敞口 = 保证金 × 杠杆
# BINANCE_LEVERAGE=10                     # 杠杆倍数
# BINANCE_MAX_POSITIONS=3                 # 最大同时持仓数
# BINANCE_EXPIRE_HOURS=4                  # 持仓到期自动平仓时限（小时）
