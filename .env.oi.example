# Next K API — King Keltner 实盘（官方 vnpy_binance）
# 复制为 next-k-api/.env.oi

NEXT_K_EMBED_SCHEDULER=1

# ═══════════════════════════════════════════════════════════════
# King Keltner — 唯一交易策略
# ═══════════════════════════════════════════════════════════════
# vnpy = 官方 CTA + BinanceLinearGateway 直连币安
KK_ENGINE=vnpy
KK_ENABLED=1
KK_LIVE_ENABLED=1

# 币安 API（实盘 Key；若绑 IP 白名单，next-k-api 出口须为静态 IP）
BINANCE_API_KEY=
BINANCE_API_SECRET=
# BINANCE_SERVER=REAL
# BINANCE_SERVER=TESTNET
# BINANCE_KLINE_STREAM=False
# BINANCE_PROXY_HOST=
# BINANCE_PROXY_PORT=0

# 标的池（config/kk/symbols.txt）
# KK_SYMBOLS=INTC,SOXL,HOOD

KK_EQUITY_USDT=14
KK_RISK_PCT=0.01
KK_MAX_OPEN_POSITIONS=7
KK_LIVE_LEVERAGE=5

KK_RTH_ONLY=1
KK_EOD_FLAT=1
KK_EXIT_HOUR=15
KK_EXIT_MINUTE=55
KK_MACRO_FILTER=1

KK_VNPY_AUTO_START=1
# KK_VNPY_IDLE_OUTSIDE_RTH=1
# KK_SHADOW=1

# 纸面引擎（KK_ENGINE=paper）+ KK_LIVE_ENABLED=1 时仍走 Protocol ingest（与 vnpy 直连分离）

# BINANCE_FAPI_BASE=https://fapi.binance.com
