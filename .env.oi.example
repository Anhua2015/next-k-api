# Next K API — 本地 / Railway 环境变量示例
# 复制为 next-k-api/.env.oi

NEXT_K_EMBED_SCHEDULER=1

# DATA_DIR=/data
# NEXT_K_EXPORT_VOLUME_ENABLED=1

# ORB 过滤（V2 推荐：宏观开）
# ORB_MACRO_FILTER=1

# ORB_SCAN_INTERVAL_MINUTES=5
# ORB_SCAN_CRON_SECOND=5

# ORB 每标 bot 初始本金（U）
# ORB_SYMBOL_BOT_EQUITY=1000

# ORB 2.0 扫描标的（默认 config/orb/v2/symbols.txt = COIN + CRCL）
# ORB_V2_SYMBOLS=
# ORB_V2_SYMBOLS_FILE=  留空；默认 config/orb/v2/symbols.txt

# ORB 实盘 → Next-k-protocol（ORB_LIVE_ENABLED=1 时必须设 PROTOCOL_API_URL）
# ORB_LIVE_ENABLED=0
# PROTOCOL_API_URL=http://localhost:8001
# ORB_LIVE_LEVERAGE=5
# ORB_LIVE_ENTRY_TYPE=stoplimit_gap
# ORB_ARM_AT_OR_CLOSE=1
# ORB_PREPLACE_OCO=1
# ORB_MAX_CHASE_TICKS=30
# ORB_PREPLACE_RISK_PCT=0
# ORB_PREPLACE_RISK_SCALE=1.0   # 默认不叠 scale；有效风险已由 ORB_POSITION_SAFETY_PCT(0.15) 压到 ~0.85×risk_pct
# ORB_LEVERAGE=5
# ORB_MARGIN_USDT=100

# --- ORB 2.0（ML Live Gate）---
# ORB_V2_ENABLED=1
# ORB_V2_SCHEDULER_ENABLED=1
# 实盘参数统一在 orb_live/（Gate + 模型），直接覆盖文件后 git 部署即可
# ORB_LIVE_BUNDLE_ROOT=  留空；默认 orb_live/
# ORB_V2_MONTHLY_TRAIN_ENABLED=0
# 关闭 ML p / BS / early-trap 过滤（默认关）；=1 恢复 ML 开单过滤
# ORB_V2_GATE_ML=0
# ORB_ML_KLINE_REFRESH_ENABLED=1
# ORB_ML_KLINE_DAYS=180
# ORB_KLINE_CACHE_ROOT=data/orb/kline
# ORB_V2_ROBOT_COUNT=2
# 单 robot 本金(U)；COIN+CRCL 各 1000U
# ORB_V2_ROBOT_EQUITY=1000
# 每 robot 绑定 symbols.txt 同序标的一；=0 恢复共享资金池
# ORB_V2_ROBOT_BOUND=1
