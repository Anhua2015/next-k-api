# CrackingMarkets — Day Trading Volatility Breakouts（Blueprint 公开基线）
# 前收 ± k×ATR 突破 | k×ATR 止损 | EOD | 0.33% 风险 | 1m | 一日一单
# 参考：https://www.crackingmarkets.com/intraday-volatility-breakout-blueprint/

ORB_MARKET=us_equity
ORB_ENTRY_MODE=vol_breakout
ORB_SYMBOLS=SPYUSDT,QQQUSDT,IWMUSDT,DIAUSDT

ORB_SIGNAL_INTERVAL=1m
ORB_RISK_PCT=0.0033
ORB_ONE_TRADE_PER_SESSION=1
ORB_EXIT_MODE=eod

ORB_ATR_PERIOD=14
ORB_ATR_BREAKOUT_MULT=0.33
ORB_ATR_SL_FRACTION=0.33
ORB_SL_MODE=atr_pct

ORB_ARM_AT_OR_CLOSE=1
ORB_PREPLACE_OCO=1
ORB_ENTRY_TICK_OFFSET=2
ORB_VOL_MULT=0
ORB_MACRO_FILTER=0
ORB_TRADE_WINDOW_MINUTES=0

ORB_SYMBOL_BOT_EQUITY_USDT=1000
ORB_V2_ROBOT_EQUITY=1000
ORB_V2_ROBOT_RESET_CAP=0
ORB_V2_GATE_ML=0
