# ORB 实盘公共层 — 与 config/orb/COIN、config/orb/CRCL/strategy.env 叠加
# 标的池默认 config/orb/v2/symbols.txt（COIN + CRCL）

ORB_MARKET=us_equity
ORB_MACRO_FILTER=0
ORB_V2_GATE_ML=0

ORB_ENTRY_MODE=breakout
ORB_ARM_AT_OR_CLOSE=1
ORB_PREPLACE_OCO=1
ORB_EXIT_MODE=eod
ORB_SL_MODE=atr_pct
ORB_ATR_PERIOD=14
ORB_ATR_SL_FRACTION=0.05
ORB_ONE_TRADE_PER_SESSION=1
ORB_SIGNAL_INTERVAL=5m

ORB_V2_ROBOT_COUNT=2
ORB_V2_ROBOT_BOUND=1
ORB_V2_ROBOT_EQUITY=1000
